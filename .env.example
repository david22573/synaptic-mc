# LLM Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_MODEL=deepseek/deepseek-v3.2

# Server Configuration
DEBUG=false

# Security & Access
# Leave ALLOWED_ORIGIN blank or * to allow all origins
ALLOWED_ORIGIN=http://localhost:3000
# Token required for UI Dashboard and /api/config. Leave blank to disable auth.
API_TOKEN=super_secret_token_here